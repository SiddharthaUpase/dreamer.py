{
  "name": "agent-vas-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:all": "concurrently -n api,worker -c cyan,magenta \"npm run dev\" \"npm run dev:worker\"",
    "build": "tsc && cp -r src/agent/prompts dist/agent/prompts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@blaxel/core": "^0.2.71",
    "@hyperbrowser/sdk": "^0.86.0",
    "@langchain/anthropic": "^1.3.12",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/openai": "^1.2.3",
    "@mendable/firecrawl-js": "^4.16.0",
    "@neondatabase/serverless": "^1.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "bullmq": "^5.73.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "langchain": "^1.2.13",
    "multer": "^2.1.1",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
